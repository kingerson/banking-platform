# ──────────────────────────────────────────────────────────
# Banking Platform - Environment Variables
# ──────────────────────────────────────────────────────────

# ── Kafka Configuration ──
KAFKA_BROKERS=localhost:9092
# Para múltiples brokers: KAFKA_BROKERS=broker1:9092,broker2:9092,broker3:9092

# ── Redis Configuration ──
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Customer Service ──
# PORT=3001
# DB_HOST=localhost
# DB_PORT=5433
# DB_NAME=customers_db
# DB_USER=customers_user
# DB_PASSWORD=customers_pass
# DATABASE_URL=postgresql://customers_user:customers_pass@localhost:5433/customers_db

# ── Transaction Service ──
# PORT=3002
# DB_HOST=localhost
# DB_PORT=5434
# DB_NAME=transactions_db
# DB_USER=transactions_user
# DB_PASSWORD=transactions_pass
# DATABASE_URL=postgresql://transactions_user:transactions_pass@localhost:5434/transactions_db

# ── AI Service ──
# PORT=3003
# DB_HOST=localhost
# DB_PORT=5435
# DB_NAME=ai_db
# DB_USER=ai_user
# DB_PASSWORD=ai_pass
# DATABASE_URL=postgresql://ai_user:ai_pass@localhost:5435/ai_db
# LLM_PROVIDER=mock
# LLM_API_KEY=your-api-key-here
# LLM_MODEL=claude-sonnet-4-20250514

# ── GraphQL Gateway ──
# PORT=4000
# CUSTOMER_SERVICE_URL=http://localhost:3001
# TRANSACTION_SERVICE_URL=http://localhost:3002
# AI_SERVICE_URL=http://localhost:3003

# ── API Gateway ──
# PORT=3000
# CUSTOMER_SERVICE_URL=http://localhost:3001
# TRANSACTION_SERVICE_URL=http://localhost:3002
# AI_SERVICE_URL=http://localhost:3003
# JWT_SECRET=banking-platform-secret-key-2024
# JWT_EXPIRES_IN=24h
