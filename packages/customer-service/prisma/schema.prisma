// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id             String    @id @default(uuid()) @db.Uuid
  name           String    @db.VarChar(255)
  email          String    @unique @db.VarChar(255)
  documentNumber String    @map("document_number") @db.VarChar(20)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  accounts       Account[]

  @@map("clients")
}

model Account {
  id            String   @id @default(uuid()) @db.Uuid
  clientId      String   @map("client_id") @db.Uuid
  accountNumber String   @unique @map("account_number") @db.VarChar(20)
  balance       Decimal  @default(0) @db.Decimal(15, 2)
  currency      String   @default("USD") @db.VarChar(3)
  status        String   @default("active") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model ProcessedEvent {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @unique @map("event_id") @db.Uuid
  subject     String   @db.VarChar(100)
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz(6)

  @@index([eventId])
  @@map("processed_events")
}

model Outbox {
  id            String    @id @default(uuid()) @db.Uuid
  subject       String    @db.VarChar(100)
  payload       Json      @db.JsonB
  correlationId String?   @map("correlation_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  publishedAt   DateTime? @map("published_at") @db.Timestamptz(6)
  attempts      Int       @default(0)
  lastError     String?   @map("last_error") @db.Text

  @@index([createdAt])
  @@index([publishedAt])
  @@index([correlationId])
  @@map("outbox")
}
